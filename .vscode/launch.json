{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "(gdb) Launch GUI",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/gui.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    }
  ]
}